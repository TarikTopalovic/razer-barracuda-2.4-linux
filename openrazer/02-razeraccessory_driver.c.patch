+        return count;
+
     default:
         printk(KERN_WARNING "razeraccessory: Unknown device\n");
         return -EINVAL;
@@ -1331,6 +1351,12 @@
         request.transaction_id.id = 0xFF;
         break;
 
+    case USB_DEVICE_ID_RAZER_BARRACUDA_2_4:
+        // Vendor (PI/PA) protocol; report a static mode (no legacy transport).
+        buf[0] = 0x00;
+        buf[1] = 0x00;
+        return 2;
+
     default:
         printk(KERN_WARNING "razeraccessory: Unknown device\n");
         return -EINVAL;
@@ -2379,6 +2405,7 @@
