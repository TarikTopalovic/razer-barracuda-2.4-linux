+        return sprintf(buf, "v1.0\n");
+
     default:
         printk(KERN_WARNING "razeraccessory: Unknown device\n");
         return -EINVAL;
@@ -1260,6 +1275,11 @@
         request.transaction_id.id = 0xFF;
         break;
 
+    case USB_DEVICE_ID_RAZER_BARRACUDA_2_4:
